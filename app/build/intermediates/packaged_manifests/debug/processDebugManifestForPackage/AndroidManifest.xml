<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.nezhahq.agent"
    android:versionCode="1"
    android:versionName="1.0" >

    <!--
        Shizuku API 13.1.5 声明 minSdkVersion=24，但其 API 仅在用户手动开启
        Root/Shizuku 模式时才被调用（有运行时判断保护），强制覆盖不会导致崩溃。
        Shizuku Provider 库本身已支持 minSdk=23。
    -->
    <uses-sdk
        android:minSdkVersion="23"
        android:targetSdkVersion="34" />

    <!-- 网络访问 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- 前台服务保活：WakeLock 防止 CPU 睡眠，REQUEST_IGNORE_BATTERY_OPTIMIZATIONS 申请豁免 Doze -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ 专用前台服务类型权限（需与 startForeground 中传入的类型一致） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Android 13 (API 33)+ 通知权限：不申请则前台服务通知不显示，保活优先级下降 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 悬浮窗保活权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- 开机自启权限 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 硬件/系统信息读取 -->
    <uses-permission android:name="android.permission.BATTERY_STATS" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" />

    <!-- 短信读取（虚拟指令 @agent sms 使用，需要用户手动授权） -->
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- VPN 流量计量（本地透传 VPN，仅计量不拦截，作为网络统计的最后降级策略） -->
    <uses-permission android:name="android.permission.BIND_VPN_SERVICE" />

    <!--
        文件管理器完整访问权限（TaskType 11 / 文件浏览/下载/上传）。
        - READ/WRITE_EXTERNAL_STORAGE：Android 10 及以下使用
        - MANAGE_EXTERNAL_STORAGE（Android 11+）：绕过 Scoped Storage FUSE 过滤，
          使 File.listFiles() 能返回完整的文件+目录列表（否则 FUSE 层只返回目录）。
          需要用户在系统设置中手动授权「所有文件访问」。
    -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <permission
        android:name="com.nezhahq.agent.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.nezhahq.agent.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:requestLegacyExternalStorage="true"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.NezhaAgent" >
        <activity
            android:name="com.nezhahq.agent.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.NezhaAgent" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            前台服务：声明 dataSync|specialUse 两种类型，
            代码中根据 API 级别在运行时选择使用哪种类型：
              - API 10~33: FOREGROUND_SERVICE_TYPE_DATA_SYNC
              - API 34+  : FOREGROUND_SERVICE_TYPE_SPECIAL_USE（保活更稳定）
        -->
        <service
            android:name="com.nezhahq.agent.service.AgentService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync|specialUse" >

            <!--
                Android 14 (API 34)+ 要求为 specialUse 类型的前台服务提供用途说明。
                此属性用于 Google Play 审核和系统日志，描述该服务的实际功能。
            -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="哪吒探针系统监控服务：持续采集设备 CPU、内存、网络等运行指标，并通过 gRPC 上报至哪吒监控面板，实现设备实时运行状态监控。" />
        </service>

        <!--
            Shizuku ContentProvider：用于从 Shizuku 应用获取 Binder，
            实现 ADB 级别权限的 Shell 执行能力。
            - exported="true"：Shizuku 框架要求必须对外公开
            - INTERACT_ACROSS_USERS_FULL 权限保护：防止普通 App 访问
            - multiprocess="false"：单进程模式，确保 Binder 一致性
        -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="com.nezhahq.agent.shizuku"
            android:enabled="true"
            android:exported="true"
            android:multiprocess="false"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <!--
            开机自启接收器。
            - android:exported="false"：防止第三方 App 伪造广播触发服务。
            - BOOT_COMPLETED 被列入 Android 8.0+ 隐式广播豁免名单，可正常接收。
            - MY_PACKAGE_REPLACED 在应用更新后触发，自动恢复探针运行。
        -->
        <receiver
            android:name="com.nezhahq.agent.BootReceiver"
            android:exported="false" >
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!--
            VPN 流量计量服务：在无 Root/Shizuku 且 Android < 12 的设备上，
            通过本地 VPN 隧道透传所有流量并统计 rx/tx 字节数。
            仅计量不拦截、不修改任何数据包内容。用户可在工具页手动开关。
        -->
        <service
            android:name="com.nezhahq.agent.service.TrafficVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE" >
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- 无障碍保活服务：提高进程优先级，防止系统杀后台 -->
        <service
            android:name="com.nezhahq.agent.service.KeepAliveAccessibilityService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE" >
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <activity
            android:name="androidx.compose.ui.tooling.PreviewActivity"
            android:exported="true" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.nezhahq.agent.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <activity
            android:name="androidx.activity.ComponentActivity"
            android:exported="true" />

        <meta-data
            android:name="moe.shizuku.client.V3_SUPPORT"
            android:value="true" />

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>